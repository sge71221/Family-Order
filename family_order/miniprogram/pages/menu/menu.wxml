<!-- menu.wxml — 菜单页面模板 -->
<view class="menu-page page-container">
  <!-- 离线提示 -->
  <offline-banner isOffline="{{isOffline}}" bind:retry="onNetworkRetry"></offline-banner>

  <!-- 搜索栏 + 添加按钮 -->
  <view class="search-row">
    <search-bar class="search-row__input" placeholder="搜索菜品..." value="{{keyword}}"
                historyList="{{searchHistory}}"
                bind:input="onSearchInput" bind:search="onSearch"
                bind:clear="onSearchClear" bind:clearhistory="onClearHistory"></search-bar>
    <view class="add-btn" hover-class="add-btn--hover" bind:tap="onAddDish">
      <view class="add-btn__icon">+</view>
    </view>
  </view>

  <view class="menu-body">
    <!-- 左侧分类栏 -->
    <category-tab class="menu-sidebar" categories="{{categories}}" activeId="{{activeCategory}}"
                  mode="vertical" bind:change="onCategoryChange"></category-tab>

    <!-- 右侧菜品列表 -->
    <view class="menu-main">
      <!-- 骨架屏 -->
      <skeleton type="card" count="{{5}}" wx:if="{{loading}}"></skeleton>

      <scroll-view class="menu-list" scroll-y wx:if="{{!loading}}">
        <view class="menu-list__item" wx:for="{{filteredDishes}}" wx:key="_id">
          <dish-card dish="{{item}}" showTags="{{true}}" showConflict="{{true}}"
                     showAdd="{{true}}" showFavorite="{{false}}"
                     dietaryConflict="{{dietaryConflictMap[item._id]}}"
                     stockWarning="{{stockWarningMap[item._id]}}"
                     bind:cardtap="onDishTap" bind:addtap="onAddToCart"></dish-card>
        </view>
      </scroll-view>

      <!-- 空状态 -->
      <empty-state title="暂无菜品" description="快去添加一道家传菜吧"
                   actionText="添加菜品" wx:if="{{!loading && filteredDishes.length === 0}}"
                   bind:action="onAddDish"></empty-state>
    </view>
  </view>

  <!-- 底部购物车栏 -->
  <cart-bar class="menu-cart-bar" itemCount="{{cartCount}}" totalCostFen="{{cartTotalFen}}" buttonText="提交订单"
            bind:submit="onSubmitOrder" bind:viewcart="onViewCart"></cart-bar>
</view>
