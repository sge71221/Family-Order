/** menu.wxss */
@import '../../styles/mixins.wxss';

.menu-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(var(--tab-bar-height) + var(--bottom-bar-height) + env(safe-area-inset-bottom));
}

.menu-body {
  display: flex;
  flex-direction: row;
  flex: 1;
  overflow: hidden;
}

.menu-sidebar {
  width: 160rpx;
  flex-shrink: 0;
  height: 100%;
  border-right: 1rpx solid var(--color-divider);
}

.menu-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  height: 100%;
}

.menu-list {
  flex: 1;
  height: 100%;
  padding: var(--spacing-xs) var(--spacing-sm);
}

.menu-list__item {
  margin-bottom: var(--spacing-xs);
}

/* 悬浮添加按钮 */
.fab {
  position: fixed;
  right: var(--spacing-sm);
  bottom: calc(var(--tab-bar-height) + var(--bottom-bar-height) + 16px + env(safe-area-inset-bottom));
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-card-hover);
  z-index: var(--z-fixed);
  transition: transform var(--transition-fast), background var(--transition-fast);
}

.fab--hover {
  transform: scale(0.92);
  background: var(--color-primary-deep);
}

.fab__icon {
  font-size: 28px;
  font-weight: var(--font-weight-bold);
  line-height: 1;
}

/* 底部购物车栏 — 位置由 cart-bar 组件内部动态计算（根据设备安全区域和 tabBar 高度） */
