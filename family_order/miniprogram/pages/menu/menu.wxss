/** menu.wxss */
@import '../../styles/mixins.wxss';

.menu-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(var(--tab-bar-height) + env(safe-area-inset-bottom));
}

.menu-body {
  display: flex;
  flex-direction: row;
  flex: 1;
  overflow: hidden;
}

.menu-sidebar {
  width: 160rpx;
  flex-shrink: 0;
  height: 100%;
  border-right: 1rpx solid var(--color-divider);
}

.menu-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  height: 100%;
}

.menu-list {
  flex: 1;
  height: 100%;
  padding: var(--spacing-xs) var(--spacing-sm) calc(var(--spacing-xs) + var(--bottom-bar-height));
}

.menu-list__item {
  margin-bottom: var(--spacing-xs);
}

/* 搜索栏行 */
.search-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-xs);
  gap: var(--spacing-xs);
}

.search-row__input {
  flex: 1;
  min-width: 0;
}

/* 添加按钮 */
.add-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-card-hover);
  transition: transform var(--transition-fast), background var(--transition-fast);
  flex-shrink: 0;
  margin-right: 0;
}

.add-btn--hover {
  transform: scale(0.92);
  background: var(--color-primary-deep);
}

.add-btn__icon {
  font-size: 24px;
  font-weight: var(--font-weight-bold);
  line-height: 1;
}

