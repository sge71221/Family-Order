<!-- stats.wxml -->
<view class="stats-page page-container">
  <!-- 页面标题 + 月份选择 -->
  <view class="stats-header flex-row flex-between">
    <view class="stats-title">
      <text class="stats-title__icon">📊</text>
      <text class="stats-title__text">饮食统计</text>
    </view>
    <picker mode="date" fields="month" value="{{currentMonth}}" bindchange="onMonthChange">
      <view class="stats-header__month flex-row">
        <text>{{currentMonth}}</text>
        <text class="stats-header__arrow">▼</text>
      </view>
    </picker>
  </view>

  <skeleton type="card" count="{{2}}" wx:if="{{loading}}"></skeleton>

  <view wx:if="{{!loading && summary}}">
    <!-- 月度汇总 -->
    <view class="stats-summary flex-row flex-between">
      <view class="summary-card">
        <text class="summary-card__value text-primary">¥{{summary.totalCostYuan}}</text>
        <text class="summary-card__label">本月开销</text>
      </view>
      <view class="summary-card">
        <text class="summary-card__value text-success">{{summary.orderCount}}次</text>
        <text class="summary-card__label">点餐次数</text>
      </view>
      <view class="summary-card">
        <text class="summary-card__value text-success">{{summary.mostPopularDish}}</text>
        <text class="summary-card__label">最受欢迎</text>
      </view>
    </view>

    <!-- 日消费趋势 -->
    <view class="stats-trend" wx:if="{{dailyTrend.length > 0}}">
      <text class="section-title">月度开销趋势</text>
      <view class="card-surface">
        <bar-chart data="{{dailyTrend}}" height="180" barColor="#F4A261"></bar-chart>
      </view>
    </view>

    <!-- 菜品排行 -->
    <view class="stats-ranking" wx:if="{{topDishes.length > 0}}">
      <view class="section-title">
        <text class="section-title__icon">🔥</text>
        <text>高频菜品排行</text>
      </view>
      <view class="ranking-list card-surface">
        <view class="ranking-item flex-row flex-between" wx:for="{{topDishes}}" wx:key="dishId">
          <view class="ranking-item__rank {{index < 3 ? 'ranking-item__rank--top' : ''}}">
            {{index + 1}}
          </view>
          <text class="ranking-item__name">{{item.dishName}}</text>
          <text class="ranking-item__count">{{item.orderCount}}次</text>
        </view>
      </view>
    </view>
  </view>

  <empty-state title="暂无统计数据" description="开始点餐后自动生成统计"
               wx:if="{{!loading && !summary}}"></empty-state>
</view>
