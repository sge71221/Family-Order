<!-- cart.wxml -->
<view class="cart-page page-container">
  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item flex-row flex-between" wx:for="{{cartItems}}" wx:key="dishId">
      <image class="cart-item__image" src="{{item.dishImage || '/assets/icons/dish-placeholder.png'}}" mode="aspectFill"></image>
      <view class="cart-item__info flex-1">
        <text class="cart-item__name text-ellipsis">{{item.dishName}}</text>
        <text class="cart-item__notes text-muted" wx:if="{{item.notes}}">{{item.notes}}</text>
        <text class="cart-item__price text-primary">¥{{item.totalPriceYuan || ''}}</text>
      </view>
      <view class="cart-item__controls">
        <quantity-stepper value="{{item.quantity}}" min="1" max="10"
                          data-index="{{index}}" bind:change="onQuantityChange"></quantity-stepper>
      </view>
      <text class="cart-item__remove" data-index="{{index}}" catchtap="onRemoveItem">×</text>
    </view>
  </view>

  <empty-state title="购物车为空" description="快去点几道菜吧"
               actionText="去点餐" wx:if="{{cartItems.length === 0}}"
               bind:action="onGoOrder"></empty-state>

  <view class="cart-footer bottom-bar flex-row flex-between" wx:if="{{cartItems.length > 0}}">
    <view class="cart-footer__info">
      <text class="cart-footer__label">共{{itemCount}}道菜</text>
      <text class="cart-footer__total">¥{{totalCostYuan}}</text>
    </view>
    <view class="cart-footer__actions flex-row">
      <text class="cart-footer__clear text-muted" bindtap="onClearCart">清空</text>
      <button class="btn-primary" bindtap="onSubmit">提交订单</button>
    </view>
  </view>
</view>
