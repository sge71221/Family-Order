/** dish-detail.wxss */
@import '../../styles/mixins.wxss';

.dish-detail-page {
  padding-bottom: calc(var(--bottom-bar-height) + env(safe-area-inset-bottom));
}

.dish-detail__images {
  width: 100%;
  height: 280px;
}

.dish-detail__image {
  width: 100%;
  height: 100%;
}

.dish-detail__header {
  margin: var(--spacing-sm);
}

.dish-detail__name {
  font-size: var(--font-size-title);
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.dish-detail__meta {
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-xs);
}

.dish-detail__category, .dish-detail__difficulty, .dish-detail__time {
  font-size: var(--font-size-caption);
  color: var(--color-on-surface-muted);
}

.dish-detail__cost {
  font-size: var(--font-size-body);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  display: block;
  margin-top: var(--spacing-xs);
}

.dish-detail__conflict {
  margin: var(--spacing-sm);
  padding: var(--spacing-sm);
  border-left: 4rpx solid var(--color-allergen-severe);
}

.conflict-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: var(--spacing-xs);
}

.dislike-text {
  font-size: var(--font-size-caption);
  color: var(--color-on-surface-muted);
}

.dish-detail__ingredients, .dish-detail__steps, .dish-detail__tips {
  margin: var(--spacing-sm);
}

.ingredient-row {
  display: flex;
  justify-content: space-between;
  padding: 4rpx 0;
}

.ingredient-name {
  font-size: var(--font-size-body);
  color: var(--color-on-surface);
}

.ingredient-qty {
  font-size: var(--font-size-body);
  color: var(--color-on-surface-muted);
}

.step-item {
  display: flex;
  flex-direction: row;
  padding: var(--spacing-xs) 0;
  gap: var(--spacing-xs);
}

.step-number {
  width: 24px;
  height: 24px;
  border-radius: 12px;
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: var(--font-size-caption);
  text-align: center;
  line-height: 24px;
  flex-shrink: 0;
}

.step-text {
  font-size: var(--font-size-body);
  color: var(--color-on-surface);
  flex: 1;
}

.tips-text {
  font-size: var(--font-size-body);
  color: var(--color-on-surface-muted);
  line-height: 1.6;
}

.dish-detail__actions {
  padding: var(--spacing-xs) var(--spacing-sm);
}

.action-left {
  flex: 1;
  gap: var(--spacing-sm);
  align-items: center;
}

.notes-input {
  flex: 1;
  height: var(--button-min-height);
  background-color: var(--color-surface);
  border: 2rpx solid var(--color-divider);
  border-radius: var(--radius-input);
  padding: 0 var(--spacing-xs);
  font-size: var(--font-size-body);
}

.dish-detail__edit {
  padding: var(--spacing-sm);
  text-align: center;
}

.edit-text {
  font-size: var(--font-size-body);
  color: var(--color-primary);
}
