/** dish-image.wxss */
@import '../../styles/mixins.wxss';

.dish-image-list {
  gap: var(--spacing-xs);
}

.dish-image-item {
  width: var(--image-size-medium);
  height: var(--image-size-medium);
  border-radius: var(--radius-image);
  overflow: hidden;
  position: relative;
  background-color: var(--color-surface-alt);
}

.dish-image-item__img {
  width: 100%;
  height: 100%;
}

.dish-image-item__delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 24px;
  height: 24px;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 0 var(--radius-image) 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #FFFFFF;
  font-size: 14px;
}

.dish-image-item--add {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed var(--color-divider);
}

.add-icon {
  font-size: 32px;
  color: var(--color-on-surface-muted);
}
