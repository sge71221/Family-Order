<!-- category-tab.wxml -->
<scroll-view class="category-tab-scroll" scroll-x enable-flex>
  <view class="category-tab-list flex-row">
    <view class="category-tab-item {{activeId === item.id ? 'category-tab-item--active' : ''}}"
          wx:for="{{categories}}" wx:key="id"
          data-id="{{item.id}}" bindtap="onTabTap">
      <text class="category-tab-item__name">{{item.name}}</text>
    </view>
  </view>
</scroll-view>
