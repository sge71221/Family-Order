<!-- category-tab.wxml -->
<scroll-view class="category-tab-scroll category-tab-scroll--{{mode}}" scroll-x="{{mode === 'horizontal'}}" scroll-y="{{mode === 'vertical'}}" enable-flex>
  <view class="category-tab-list category-tab-list--{{mode}}">
    <view class="category-tab-item category-tab-item--{{mode}} {{activeId === item.id ? 'category-tab-item--active' : ''}}"
          wx:for="{{categories}}" wx:key="id"
          data-id="{{item.id}}" bindtap="onTabTap">
      <text class="category-tab-item__name">{{item.name}}</text>
    </view>
  </view>
</scroll-view>
